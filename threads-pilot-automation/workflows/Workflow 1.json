    {
      "parameters": {
        "jsCode": "// Ambil SEMUA post dari Code in JavaScript3 (sekarang multi-item, 1 post per item)\nconst posts = $('Code in JavaScript12').all().map(item => item.json);\n\nif (!posts || posts.length === 0) {\n  throw new Error('Tidak ada posts dari Code in JavaScript3');\n}\n\n// Susun preview text: nomori tiap post biar jelas ini thread multi-post\nconst previewText = posts\n  .sort((a, b) => a.post_order - b.post_order)\n  .map((p, i) => `${i + 1}/${posts.length}\\n${p.content}`)\n  .join('\\n\\n---\\n\\n');\n\nconst angle = posts[0].angle;\nconst topic = posts[0].topic;\n\n// draft_id dari node Create a row\nconst draftId = $('Create a row2').item.json.id;\n\nreturn [{\n  json: {\n    preview_text: previewText,\n    angle: angle,\n    topic: topic,\n    draft_id: draftId\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
