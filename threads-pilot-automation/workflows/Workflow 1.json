    {
      "parameters": {
        "jsCode": "const parentId = $('Create a row2').item.json.id;\nconst parentData = $('Code in JavaScript13').item.json; // sesuaikan nama node\n\nconst posts = parentData.posts || [];\n\nreturn posts.map((content, index) => ({\n  json: {\n    draft_id: parentId,\n    content: String(content).trim().slice(0, 480),\n    post_order: index,\n    topic: parentData.topic,\n    angle: parentData.angle,\n    pillar_name: parentData.pillar_name\n  }\n}));"
      },
