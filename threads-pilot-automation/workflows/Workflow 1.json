        "jsCode": "const raw = $json.output;\nconst posts = (raw && raw.posts) || [];\nconst topic = (raw && raw.topic) || 'Topik tidak tersedia';\n\nreturn [{\n  json: {\n    pillar_name: 'pilot_pesawat',\n    angle: $('Get a row3').first().json.angle, // sesuaikan nama node penentu angle\n    topic: topic,\n    status: 'pending_approval',\n    posts: posts // dibawa terus buat dipecah nanti, bukan buat insert\n  }\n}];"
